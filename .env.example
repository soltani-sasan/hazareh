APP_NAME="هنرستان هزاره صنعت"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── دیتابیس ──────────────────────────────────────────────
# Laragon: DB_PASSWORD= (خالی)
# XAMPP:   DB_USERNAME=root / DB_PASSWORD=
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hazareh_db
DB_USERNAME=root
DB_PASSWORD=

# ── Cache / Session ────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail (برای ارسال پاسخ مشاوره) ────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.hazareh.ir
MAIL_PORT=587
MAIL_USERNAME=no-reply@hazareh.ir
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@hazareh.ir"
MAIL_FROM_NAME="هنرستان هزاره صنعت"

# ── پیامک ─────────────────────────────────────────────────
SMS_DRIVER=kavenegar
SMS_API_KEY=
SMS_SENDER=

# ── Sanctum (API) ─────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:8000

# ── تنظیمات هنرستان ──────────────────────────────────────
SCHOOL_PHONE=
