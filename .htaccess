# ══════════════════════════════════════════════════════════
# هنرستان هزاره صنعت — ریدایرکت ریشه به پوشه public (مخصوص cPanel)
# اگر امکان تغییر Document Root به public/ را دارید، این فایل لازم نیست
# و کافیست محتوای public/.htaccess را در اینجا استفاده نکنید.
# ══════════════════════════════════════════════════════════
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
